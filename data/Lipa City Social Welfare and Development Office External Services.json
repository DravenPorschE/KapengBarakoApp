          "processing_time": "5 days, 19 minutes",
          "person_responsible": "Social Welfare Officer IV / City Mayor"
        },
        {
          "client_step": "2. Claim allowance",
          "agency_action": "Distribute allowance by batch",
          "fees": "None",
          "processing_time": "4 hours",
          "person_responsible": "CSWDO / Lipa City Treasurer's Office"
        }
      ],
      "total": { "fees": "None", "processing_time": "5 days, 4 hours, 19 minutes" },
      "note": "Provides P5,000.00 monthly for 10 months (June to March)."
