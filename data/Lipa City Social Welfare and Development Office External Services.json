{
  "department": "Lipa City Social Welfare and Development Office",
  "external_services": [
    {
      "service_name": "Aid to Individuals/ Families in Crisis Situation (AICS)",
      "image": "/assets/document_background/AICS Financial Assistance",
      "office": "Lipa City Social Welfare and Development Office",
      "classification": "Highly Technical",
      "type_of_transaction": "G2C",
      "who_may_avail": "Individuals/Families experiencing sickness, job loss, or calamity",
      "checklist_of_requirements": [
        { "requirement": "Letter of request to City Mayor", "source": "Lipa City Mayor's Office" },
        { "requirement": "Certification of Indigency/Residency", "source": "Barangay Hall" },
        { "requirement": "Social Case Study Report", "source": "CSWDO" },
        { "requirement": "Hospital billing/Prescription/Proof of crisis", "source": "Medical Institution" },
        { "requirement": "Valid Government ID", "source": "Requesting party" }
      ],
      "steps": [
        {
          "client_step": "1. Secure action slip/endorsement",
          "agency_action": "Issue endorsement to CSWDO",
          "fees": "None",
          "processing_time": "5 minutes",
          "person_responsible": "Lipa City Mayor's Office"
        },
        {
          "client_step": "2. Submit requirements to CSWDO",
          "agency_action": "2.1-2.4. Interview, assessment, and preparation/approval of Social Case Study Report",
          "fees": "None",
          "processing_time": "30 minutes",
          "person_responsible": "Social Welfare Officer III/IV"
        },
        {
          "client_step": "3. Wait for internal processing",
          "agency_action": "2.5-2.7. Endorse to Mayor for signature; process disbursement voucher and payroll",
          "fees": "None",
          "processing_time": "15 days",
          "person_responsible": "City Mayor / CSWDO Staff"
        },
        {
          "client_step": "4. Claim financial assistance",
          "agency_action": "2.8. Distribute AICS assistance by batch",
          "fees": "None",
          "processing_time": "2 hours",
          "person_responsible": "CSWDO / Treasurer's Office"
        }
      ],
      "total": { "fees": "None", "processing_time": "15 days, 2 hours, 35 minutes" }
    },
