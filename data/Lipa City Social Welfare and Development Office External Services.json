        },
        {
          "client_step": "4. Claim Solo Parent ID",
          "agency_action": "Release Identification Card",
          "fees": "None",
          "processing_time": "7 days",
          "person_responsible": "Social Welfare Officer / Administrative Aide II"
        }
      ],
      "total": { "fees": "None", "processing_time": "7 days, 1 hour, 30 minutes" },
