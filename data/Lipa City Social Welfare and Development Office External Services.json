        { "requirement": "Report Card (1 photocopy)", "source": "Current School" },
        { "requirement": "Valid ID of claimant", "source": "Requesting party" }
      ],
      "steps": [
        {
          "client_step": "1. Secure action slip/endorsement from Mayor's Office",
