          "processing_time": "3 minutes",
          "person_responsible": "ER Nurse on Duty"
        },
        {
          "client_steps": "2. Cooperate in History taking and Physical Assessment",
          "agency_action": "2. Assessment of patient, obtain medical history, perform physical assessment, order treatment plan, refer to Consultant if necessary",
          "fees_to_be_paid": "None",
          "processing_time": "10 minutes",
          "person_responsible": "ER Physicians"
        },
        {
          "client_steps": "3. Cooperate in Treatment/ interventions.",
          "agency_action": "3. Carry out doctor’s order, enter requests to HIMS, administer medication, perform procedure",
          "fees_to_be_paid": "None",
          "processing_time": "30 minutes – 2 hours",
          "person_responsible": "ER Physician/ Consultant, ER Nurse on Duty"
        },
        {
          "client_steps": "4. Cooperate in Treatment / interventions. Wait for further instructions",
          "agency_action": "4. Evaluate result of diagnostic procedure, and patient response to treatment. Advice for disposition.",
          "fees_to_be_paid": "None",
          "processing_time": "5 minutes",
          "person_responsible": "ER Physician/ Consultant"
        },
        {
          "client_steps": "5. Proceed to Business Office. Present the ER Charge Slip. Pay applicable fees",
          "agency_action": "5. Process the billing statement and receive payment. Issue a Discharge Clearance Slip",
          "fees_to_be_paid": "None for Lipeños; P200.00 for non-Lipeños",
          "processing_time": "3 minutes",
          "person_responsible": "Billing Clerk / Admitting Staff"
        },
        {
          "client_steps": "6. Present the Official Receipt",
          "agency_action": "6. Record the Official Receipt No. Assist the patient if required",
          "fees_to_be_paid": "None",
          "processing_time": "1 minute",
          "person_responsible": "ER Security Guard"
        }
      ],
      "total": {
        "fees": "None for Lipeños; P200.00 for non-Lipeños",
        "time": "52 minutes - 2 hours"
      }
