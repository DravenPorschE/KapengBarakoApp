          "where_to_secure": "Attending Physician"
        }
      ],
      "steps": [
        {
          "client_steps": "1. Proceed to Triage Table. Present Admitting Orders if available. Relative / Companion: Present patient Card",
          "agency_action": "1. Perform quick assessment and check vital signs. Patient will be categorized according to condition. Secure patient old record if needed.",
