      "classification": "Highly technical",
      "type_of_transaction": "G2C – Government to Citizen, G2B – Government to Business, G2G – Government to Government",
      "who_may_avail": "Executive departments, Government and non-government agencies and organizations, Individuals and groups",
      "checklist_of_requirements": [
        {
          "requirement": "Letter of City Administrator to SP (1 original copy)",
          "where_to_secure": "Lipa City Administrator’s Office"
        },
        {
          "requirement": "Endorsement (1 original copy)",
          "where_to_secure": "Lipa City Planning and Development Office"
        },
        {
          "requirement": "Zoning Certification (1 original copy)",
          "where_to_secure": "Lipa City Planning and Development Office"
        },
        {
          "requirement": "Letter of Lot Owner/requester to City Mayor (1 original copy)",
          "where_to_secure": "Requesting party/ applicant/ lot owner"
        },
        {
          "requirement": "Real Property Tax Receipt (1 photocopy)",
          "where_to_secure": "Lipa City Treasurer’s Office"
        },
        {
          "requirement": "Tax Clearance (1 photocopy)",
          "where_to_secure": "Lipa City Treasurer’s Office"
        },
        {
          "requirement": "TCT (1 photocopy)",
          "where_to_secure": "Lipa City Assessor’s Office or Register of Deeds"
        },
        {
          "requirement": "DRPV (1 photocopy)",
          "where_to_secure": "Lipa City Assessor’s Office"
        },
        {
          "requirement": "Vicinity Map/Lot Plan (1 photocopy)",
          "where_to_secure": "Requesting party/ applicant/ lot owner"
        }
      ],
      "steps": [
        {
          "client_step": "1. Submit the letter of request and pertinent documents",
          "agency_action": "1.1. Accept documents, scan, encode in Tracking System, and include in agenda",
          "fees_to_be_paid": "None",
          "processing_time": "50 minutes",
          "person_responsible": "Journal and Minutes Division Staff"
        },
        {
          "client_step": "1. Submit the letter of request and pertinent documents",
          "agency_action": "1.2. Conduct session, refer to committee, and review documents",
          "fees_to_be_paid": "None",
          "processing_time": "1 day, 2 hours, 5 minutes",
          "person_responsible": "Members of the SP / Standing Committee Division Staff"
        },
        {
          "client_step": "2. Receive invitation letter for committee hearing",
          "agency_action": "2. Prepare invitation and necessary documents for hearing",
          "fees_to_be_paid": "None",
          "processing_time": "1 hour, 30 minutes",
          "person_responsible": "Standing Committee Division Staff"
        },
        {
          "client_step": "3. Attend the scheduled hearing and justify request",
          "agency_action": "3. Conduct hearing, evaluate, draft/finalize report, and approve on 3rd reading",
          "fees_to_be_paid": "None",
          "processing_time": "6 days, 2 hours, 45 minutes",
          "person_responsible": "Chairperson and Members of the SP"
        },
        {
          "client_step": "3. Attend the scheduled hearing and justify request",
          "agency_action": "3.1. Draft, review, print, and sign ordinance/resolution for Mayor's approval",
          "fees_to_be_paid": "None",
          "processing_time": "2 days, 4 hours, 57 minutes",
          "person_responsible": "Ordinance & Resolution Division / SP Secretary / City Mayor"
        },
        {
          "client_step": "4. Receive Order of Payment and pay at Treasurer’s Office",
          "agency_action": "4. Issue Order of Payment and Official Receipt",
          "fees_to_be_paid": "P10.00/sq. meter",
          "processing_time": "6 minutes",
          "person_responsible": "City Administrator’s Office / City Treasurer’s Office"
        },
        {
          "client_step": "5. Present the Official Receipt to the SP",
          "agency_action": "5. Verify the Official receipt",
          "fees_to_be_paid": "None",
          "processing_time": "2 minutes",
          "person_responsible": "Administrative Division Staff"
        },
        {
          "client_step": "6. Receive signed copy of ordinance or resolution",
          "agency_action": "6. Provide copy of signed ordinances to client",
          "fees_to_be_paid": "None",
          "processing_time": "10 minutes",
          "person_responsible": "Administrative Division Staff"
        }
      ],
      "total_summary": {
        "total_fees": "P10.00/sq. meter",
        "total_processing_time": "9 days, 12 hours and 25 minutes"
      }
