      "service_name": "Request for Animal Vaccination",
      "image": "/assets/document_background/Request for Animal Vaccination",
      "office": "Lipa City Veterinary Office",
      "classification": "Simple",
      "type_of_transaction": "G2C- Government to Citizens",
      "who_may_avail": [
        "Farmers",
        "Pet Owners",
        "Barangay"
      ],
      "checklist_of_requirements": [
        {
          "requirement": "Mass Vaccination: Letter of request from barangay officials concerned - 1 original, 2 photocopies",
          "source": "Barangay"
        },
        {
          "requirement": "Individual Request/ Walk-in: Valid ID - 1 original, 2 photocopies",
          "source": "Lipa City Veterinary Office"
        },
        {
          "requirement": "Vaccination record – 1 original, 2 photocopies",
          "source": "Lipa City Veterinary Office"
        },
        {
          "requirement": "Certificate of Registration, if any – 1 original, 2 photocopies",
          "source": "Lipa City Veterinary Office"
        }
      ],
      "steps": [
        {
          "client_step": "1. Log-in in the client log book",
          "agency_action": "1. Provide the log book to the client",
          "fees": "None",
          "processing_time": "1 minute",
          "person_responsible": "Officer of the Day"
        },
        {
          "client_step": "2. Submit the documents and undergo interview",
          "agency_action": "2. Receive and evaluate the documents; conduct interview",
          "fees": "None",
          "processing_time": "5 minutes",
          "person_responsible": "Admin Aide IV/VI"
        },
        {
          "client_step": "3. Wait for the schedule (Mass) or the vaccination (Individual)",
          "agency_action": "3. Set schedule (Mass) or perform the vaccination (Individual)",
          "fees": "None",
          "processing_time": "2 mins (Individual) / 7 mins (Mass)",
          "person_responsible": "Livestock Inspector / Vet. Aid"
        }
      ],
      "total_processing_time": "13 minutes (Mass) / 8 minutes (Individual)",
      "total_fees": "None"
    },
