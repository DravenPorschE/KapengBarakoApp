{
  "department": "Lipa City Mayor's Office",
  "external_services": [
    {
      "service_name": "Issuance of Job Referral, Recommendation or Endorsement",
      "image": "/assets/document_background/Issuance of Job Referral, Recommendation or Endorsement",
      "office": "Lipa City Mayor's Office",
      "classification": "Simple",
      "type_of_transaction": "G2C – Government to Citizens",
      "who_may_avail": "All",
      "checklist_of_requirements": [
        {
          "requirement": "Letter requesting for recommendation/endorsement (1 original copy)",
          "source": "Requesting party / applicant"
        },
        {
          "requirement": "Resume / Curriculum Vitae (1 original copy)",
          "source": "Requesting party / applicant"
        },
        {
          "requirement": "Personal Data Sheet, if applicable (1 original copy)",
          "source": "Requesting party / applicant"
        },
        {
          "requirement": "Fully-filled-out Action Slip (for Medical/Other referrals)",
          "source": "Lipa City Mayor's Office"
        },
        {
          "requirement": "Request letter from Barangay (for Medical/Other referrals)",
          "source": "Respective Barangay Captains"
        }
      ],
      "steps": [
        {
          "client_step": "1. Present complete requirements at the Information Desk and fill out Action Slip",
          "agency_action": "1.1. Receive/check requirements; 1.2. Provide Action Slip if complete",
          "fees": "None",
          "processing_time": "2 minutes",
          "person_responsible": "Executive Assistant I / III"
        },
        {
          "client_step": "2. Present filled-out Action Slip to the City Mayor",
          "agency_action": "2.1. Sign the Action Slip; 2.2. Prepare the endorsement/referral letter",
          "fees": "None",
          "processing_time": "30 minutes",
          "person_responsible": "City Mayor / Executive Assistant IV"
        },
        {
          "client_step": "3. Claim the requested document",
          "agency_action": "3.1. Sign and issue the endorsement letter",
          "fees": "None",
          "processing_time": "1 minute",
          "person_responsible": "City Mayor"
        }
      ],
      "total": {
        "fees": "None",
        "processing_time": "33 minutes"
      }
    },
